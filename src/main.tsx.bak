type MainTab = 'about' | 'job' | 'projects'
type ProjectMode = 'active' | 'completed'
type ProjectType = 'Client' | 'Internal'

type UtilizationPhase = {
  startDate: string
  endDate: string
  utilizationPercentage: string
}

type Project = {
  id: string
  accountName: string
  name: string
  type: ProjectType
  mode: ProjectMode
  utilizationPhases: UtilizationPhase[]
  rollOffDate?: string
}

